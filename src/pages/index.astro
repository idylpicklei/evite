---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import EnvelopeScroll from '../components/EnvelopeScroll.astro';
import Countdown from '../components/Countdown';
import { getWeddingConfig } from '../lib/config';

const config = getWeddingConfig();
const title = `${config.couple.partner1} & ${config.couple.partner2} — Wedding Invitation`;
---

<BaseLayout title={title}>
  <main>
    <EnvelopeScroll />

    <section class="below-fold">
      <div id="letter-anchor" class="letter-anchor"></div>

      <Countdown client:load weddingDate={config.weddingDate} />

      <div class="cta-section">
        <p class="cta-text">We hope you can join us for this joyous occasion.</p>
        <a href="/rsvp" class="btn">RSVP Now</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  main {
    position: relative;
    z-index: 1;
  }

  .below-fold {
    position: relative;
    z-index: 2;
    background: transparent;
    padding: 3rem 1.5rem 5rem;
    text-align: center;
  }

  .cta-section {
    margin-top: 3rem;
  }

  .cta-text {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-style: italic;
    color: color-mix(in srgb, var(--color-text) 85%, transparent);
    margin-bottom: 1.5rem;
  }
</style>

<style is:global>
  .countdown {
    max-width: 560px;
    margin: 0 auto;
  }

  .countdown-label {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .countdown-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .countdown-unit {
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
    border-radius: 0.75rem;
    padding: 1.25rem 0.5rem;
    box-shadow: 0 4px 20px color-mix(in srgb, var(--color-primary) 10%, transparent);
  }

  .countdown-value {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1;
  }

  .countdown-unit-label {
    display: block;
    margin-top: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .countdown-complete {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--color-primary);
  }

  @media (max-width: 480px) {
    .countdown-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
