---
import { getWeddingConfig, formatWeddingDate } from '../lib/config';

const config = getWeddingConfig();
const formattedDate = formatWeddingDate(config.weddingDate);
---

<section class="envelope-section" id="invitation" data-envelope>
  <div class="envelope-sticky" id="envelope-sticky">
    <div class="envelope-scene" id="envelope-scene">
      <div class="envelope" id="envelope">
        <div class="envelope-back"></div>

        <div class="envelope-cavity" id="envelope-cavity">
          <div class="invitation-card" id="invitation-card">
            <div class="lace-corners" aria-hidden="true">
              <span class="lace-corner lace-corner--tl"></span>
              <span class="lace-corner lace-corner--tr"></span>
              <span class="lace-corner lace-corner--bl"></span>
              <span class="lace-corner lace-corner--br"></span>
            </div>
            <div class="lace-border lace-border--top" aria-hidden="true"></div>
            <div class="lace-border lace-border--bottom" aria-hidden="true"></div>

            <div class="card-content" id="card-content">
              <p class="card-eyebrow">{config.invitation.headline}</p>
              <h1 class="card-names">
                {config.couple.partner1}
                <span class="ampersand">&</span>
                {config.couple.partner2}
              </h1>
              <p class="card-subhead">{config.invitation.subheadline}</p>
              <div class="card-divider"></div>
              <p class="card-date">{formattedDate}</p>
              <p class="card-venue">{config.venue.name}</p>
              <p class="card-location">{config.venue.location}</p>
            </div>
          </div>
        </div>

        <div class="envelope-front" id="envelope-front"></div>
        <div class="envelope-flap" id="envelope-flap">
          <div class="wax-seal" id="wax-seal">
            <span>A</span>
          </div>
        </div>
      </div>
    </div>

    <p class="scroll-hint" id="scroll-hint">Scroll to open</p>
  </div>
</section>

<style>
  .envelope-section {
    position: relative;
    height: 220vh;
    background: transparent;
  }

  .envelope-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    min-height: 520px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 1;
    padding: 1.5rem;
    overflow: visible;
  }

  .envelope-scene {
    perspective: 1400px;
    perspective-origin: center center;
    width: min(90vw, 420px);
    min-height: 280px;
    overflow: visible;
    transition: opacity 0.3s ease;
  }

  .envelope-scene.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .envelope {
    position: relative;
    width: 100%;
    aspect-ratio: 1.5;
    min-height: 240px;
    overflow: hidden;
  }

  .envelope-back {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--color-envelope);
    border-radius: 4px;
    box-shadow: 0 20px 60px color-mix(in srgb, var(--color-accent) 20%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .envelope-cavity {
    position: absolute;
    left: 7%;
    right: 7%;
    top: 12%;
    height: 46%;
    overflow: hidden;
    z-index: 2;
    pointer-events: none;
  }

  .envelope-front {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(
      180deg,
      var(--color-envelope) 0%,
      color-mix(in srgb, var(--color-envelope) 85%, var(--color-envelope-flap)) 100%
    );
    border-radius: 4px;
    clip-path: polygon(0 55%, 50% 85%, 100% 55%, 100% 100%, 0 100%);
    pointer-events: none;
  }

  .envelope-flap {
    position: absolute;
    inset: 0;
    z-index: 5;
    background: var(--color-envelope-flap);
    border-radius: 4px 4px 0 0;
    clip-path: polygon(0 0, 50% 55%, 100% 0);
    transform-origin: 50% 0%;
    transform: rotateX(0deg);
    backface-visibility: hidden;
    will-change: transform, opacity;
  }

  .wax-seal {
    position: absolute;
    top: 38%;
    left: 50%;
    width: 56px;
    height: 56px;
    margin-left: -28px;
    margin-top: -28px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 35% 35%,
      color-mix(in srgb, var(--color-gold) 80%, white),
      var(--color-gold)
    );
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-gold) 40%, transparent);
    z-index: 6;
  }

  .wax-seal span {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: white;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
  }

  .invitation-card {
    position: absolute;
    left: 50%;
    top: 0;
    width: 100%;
    padding: 2rem 1.5rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 252, 253, 0.98) 100%);
    border: 1px solid color-mix(in srgb, var(--color-gold) 35%, transparent);
    border-radius: 2px;
    box-shadow: 0 4px 24px color-mix(in srgb, var(--color-accent) 15%, transparent);
    text-align: center;
    will-change: transform, opacity;
    z-index: 2;
    opacity: 0;
    visibility: hidden;
  }

  .card-content {
    position: relative;
    z-index: 1;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    opacity: 0;
  }

  .card-content.is-visible {
    opacity: 1;
  }

  .lace-corners {
    position: absolute;
    inset: -10px;
    pointer-events: none;
  }

  .lace-corner {
    position: absolute;
    width: 72px;
    height: 72px;
    background: url('/lace-corner.svg') center / contain no-repeat;
    color: color-mix(in srgb, var(--color-primary) 55%, var(--color-gold));
    opacity: 0.85;
  }

  .lace-corner--tl {
    top: 0;
    left: 0;
  }

  .lace-corner--tr {
    top: 0;
    right: 0;
    transform: rotate(90deg);
  }

  .lace-corner--bl {
    bottom: 0;
    left: 0;
    transform: rotate(-90deg);
  }

  .lace-corner--br {
    bottom: 0;
    right: 0;
    transform: rotate(180deg);
  }

  .lace-border {
    position: absolute;
    left: 2.5rem;
    right: 2.5rem;
    height: 20px;
    background: url('/lace-border.svg') center / auto 100% repeat-x;
    color: color-mix(in srgb, var(--color-primary) 50%, var(--color-gold));
    opacity: 0.7;
    pointer-events: none;
  }

  .lace-border--top {
    top: 0.65rem;
  }

  .lace-border--bottom {
    bottom: 0.65rem;
    transform: scaleY(-1);
  }

  .card-eyebrow {
    font-family: var(--font-body);
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .card-names {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 3.5rem);
    color: var(--color-primary);
    line-height: 1.1;
  }

  .ampersand {
    display: block;
    font-size: 0.6em;
    color: var(--color-gold);
    margin: 0.15em 0;
  }

  .card-subhead {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-style: italic;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    margin: 1rem 0;
    line-height: 1.5;
  }

  .card-divider {
    width: 80px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-gold) 20%,
      var(--color-gold) 80%,
      transparent
    );
    margin: 1.25rem auto;
    position: relative;
  }

  .card-divider::before,
  .card-divider::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 6px;
    height: 6px;
    border: 1px solid var(--color-gold);
    border-radius: 50%;
    transform: translateY(-50%) rotate(45deg);
    background: white;
  }

  .card-divider::before {
    left: -14px;
  }

  .card-divider::after {
    right: -14px;
  }

  .card-date {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .card-venue {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .card-location {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
  }

  .scroll-hint {
    margin-top: 2rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-accent) 70%, transparent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.5;
    }
    50% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .envelope-section {
      height: auto;
      min-height: 100vh;
    }

    .envelope-sticky {
      position: relative;
      height: auto;
      min-height: 100vh;
    }

    .envelope-flap {
      transform: rotateX(-165deg) !important;
      opacity: 0 !important;
    }

    .envelope-scene.is-hidden {
      opacity: 0 !important;
    }

    .wax-seal,
    .scroll-hint {
      opacity: 0 !important;
    }
  }

  @media (max-width: 480px) {
    .invitation-card {
      padding: 1.75rem 1.25rem;
    }

    .lace-corner {
      width: 56px;
      height: 56px;
    }

    .lace-border {
      left: 1.75rem;
      right: 1.75rem;
    }

    .card-subhead {
      font-size: 0.85rem;
    }
  }
</style>

<style is:global>
  .letter-anchor {
    display: flex;
    justify-content: center;
    width: 100%;
    min-height: 1px;
    margin-bottom: 1.5rem;
  }

  .invitation-card.is-settled {
    position: relative !important;
    left: auto !important;
    top: auto !important;
    width: min(90vw, 420px) !important;
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
    margin: 0 auto;
    z-index: 10;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  let scrollTriggers: ScrollTrigger[] = [];
  let reparented = false;

  function destroyEnvelopeScroll() {
    scrollTriggers.forEach((st) => st.kill());
    scrollTriggers = [];
    reparented = false;
  }

  /** Letter is fully above the cavity opening */
  function isLetterClear(yPercent: number): boolean {
    return yPercent <= -105;
  }

  function reparentToAnchor(
    card: HTMLElement,
    anchor: HTMLElement,
    scene: HTMLElement,
  ) {
    if (reparented || !anchor) return;

    const rect = card.getBoundingClientRect();
    reparented = true;

    gsap.killTweensOf(card);
    gsap.set(card, { clearProps: 'transform,x,y,xPercent,yPercent' });
    card.style.opacity = '1';
    card.style.visibility = 'visible';
    anchor.appendChild(card);
    card.classList.add('is-settled');

    const newRect = card.getBoundingClientRect();
    gsap.set(card, {
      x: rect.left - newRect.left,
      y: rect.top - newRect.top,
    });

    scene.classList.add('is-hidden');
  }

  function initEnvelopeScroll() {
    destroyEnvelopeScroll();

    const section = document.querySelector('[data-envelope]');
    const cavity = document.getElementById('envelope-cavity');
    const scene = document.getElementById('envelope-scene');
    const flap = document.getElementById('envelope-flap');
    const card = document.getElementById('invitation-card');
    const content = document.getElementById('card-content');
    const seal = document.getElementById('wax-seal');
    const hint = document.getElementById('scroll-hint');
    const anchor = document.getElementById('letter-anchor');

    if (!section || !cavity || !scene || !flap || !card || !content || !seal) return;

    scene.classList.remove('is-hidden');
    card.classList.remove('is-settled');
    content.classList.remove('is-visible');

    if (!card.parentElement || card.parentElement !== cavity) {
      cavity.appendChild(card);
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      if (anchor) {
        anchor.appendChild(card);
        card.classList.add('is-settled');
        content.classList.add('is-visible');
        scene.classList.add('is-hidden');
      }
      return;
    }

    gsap.set(flap, { rotateX: 0, transformOrigin: '50% 0%', opacity: 1, zIndex: 5 });
    gsap.set(card, {
      xPercent: -50,
      yPercent: 140,
      opacity: 0,
      visibility: 'hidden',
      zIndex: 2,
    });
    gsap.set(content, { opacity: 0 });
    gsap.set(seal, { opacity: 1, scale: 1 });
    if (hint) gsap.set(hint, { opacity: 1 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 0.55,
        pin: '#envelope-sticky',
        pinSpacing: true,
        invalidateOnRefresh: true,
        onUpdate: (self) => {
          if (reparented) return;

          const yPercent = gsap.getProperty(card, 'yPercent') as number;
          const clear = isLetterClear(yPercent);

          gsap.set(card, {
            opacity: clear ? 1 : 0,
            visibility: clear ? 'visible' : 'hidden',
          });

          if (self.progress >= 0.78) {
            content.classList.add('is-visible');
            gsap.set(content, { opacity: 1 });
          } else if (!reparented) {
            content.classList.remove('is-visible');
            gsap.set(content, { opacity: 0 });
          }
        },
      },
    });

    scrollTriggers.push(tl.scrollTrigger!);

    /* Phase 1: open flap (0 – 0.32) */
    tl.to(flap, { rotateX: -165, ease: 'power2.inOut', duration: 0.32 }, 0)
      .to(seal, { opacity: 0, scale: 0.4, duration: 0.12 }, 0.04)
      .to(flap, { opacity: 0, zIndex: 0, duration: 0.08 }, 0.28);

    /* Phase 2: letter rises invisibly inside envelope (0.28 – 0.62) */
    tl.to(card, { yPercent: -110, ease: 'power2.inOut', duration: 0.34 }, 0.28)
      .call(
        () => {
          if (anchor) reparentToAnchor(card, anchor, scene);
        },
        [],
        0.62,
      )
      /* Phase 3: slide letter into centered anchor + hide envelope */
      .to(card, { x: 0, y: 0, ease: 'power2.out', duration: 0.16 }, 0.62)
      .to(scene, { opacity: 0, duration: 0.16, ease: 'power1.out' }, 0.62)

    /* Phase 4: reveal invitation text (0.78 – 0.92) */
    tl.to(content, { opacity: 1, duration: 0.14, ease: 'power1.out' }, 0.78);

    if (hint) {
      const hintTween = gsap.to(hint, {
        opacity: 0,
        scrollTrigger: {
          trigger: section,
          start: 'top top',
          end: '+=80',
          scrub: true,
        },
      });
      if (hintTween.scrollTrigger) {
        scrollTriggers.push(hintTween.scrollTrigger);
      }
    }

    ScrollTrigger.refresh();
  }

  function boot() {
    requestAnimationFrame(initEnvelopeScroll);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  document.addEventListener('astro:page-load', boot);
  document.addEventListener('astro:before-swap', destroyEnvelopeScroll);
  window.addEventListener('load', () => ScrollTrigger.refresh());
</script>
